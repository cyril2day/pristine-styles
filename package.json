{
  "name": "pristine-styles",
  "version": "0.1.0",
  "description": "Mobile-first reusable design tokens and base styles for projects",
  "license": "MIT",
  "author": "psi <cylonsido@gmail.com>",
  "contributors": [
    {
      "name": "cyril2day-uopeople",
      "url": "https://github.com/cyril2day-uopeople"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cyril2day-uopeople/pristine-styles"
  },
  "homepage": "https://github.com/cyril2day-uopeople/pristine-styles#readme",
  "bugs": {
    "url": "https://github.com/cyril2day-uopeople/pristine-styles/issues"
  },
  "keywords": [
    "css",
    "scss",
    "design-tokens",
    "mobile-first",
    "responsive-design",
    "themeable",
    "design-system"
  ],
  "main": "pristine-styles.css",
  "style": "pristine-styles.css",
  "exports": {
    ".": {
      "style": "./pristine-styles.css"
    },
    "./scss": "./scss/index.scss",
    "./min": "./pristine-styles.min.css"
  },
  "files": [
    "pristine-styles.css",
    "pristine-styles.min.css",
    "scss/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "sass scss/index.scss pristine-styles.css --no-source-map && sass scss/index.scss pristine-styles.min.css --no-source-map --style=compressed",
    "build:css": "sass scss/index.scss pristine-styles.css --no-source-map",
    "build:css:min": "sass scss/index.scss pristine-styles.min.css --no-source-map --style=compressed",
    "test": "echo \"No tests in core package\" && exit 0",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "sass": "^1.86.0"
  }
}
